<controls:FancyWindow
    xmlns="https://spacestation14.io"
    xmlns:graphics="clr-namespace:Robust.Client.Graphics;assembly=Robust.Client"
    xmlns:controls="clr-namespace:Content.Client.UserInterface.Controls;assembly=Content.Client"
    MinSize="700 620"
    Title="Bank Machine"
    Resizable="False">
    <!-- This is used for listing all accounts in the economy -->
    <ScrollContainer HorizontalAlignment="Left"
                     Margin="16 8 0 8"
                     HScrollEnabled="False"
                     MinSize="175 260"
                     VScrollEnabled="True">
        <PanelContainer>
            <PanelContainer.PanelOverride>
                <graphics:StyleBoxFlat BackgroundColor="#191d1e" />
            </PanelContainer.PanelOverride>
        </PanelContainer>
        <BoxContainer
            Name="Accounts"
            Margin="16 16 16 16"
            Orientation="Vertical"
            MinHeight="120"
            HorizontalExpand="True"/> <!-- Contents are autogenerated on runtime -->
    </ScrollContainer>

    <!-- This is used for operating on a specific account in the economy -->
    <BoxContainer HorizontalAlignment="Right"
                  MinSize="500 260"
                  Margin="16 8 8 8">

        <Label Name="SelectInfo"
               Text="Select an account from the menu"
               HorizontalExpand="True"
               HorizontalAlignment="Center"
               VerticalAlignment="Top"/>

        <BoxContainer
            Name="AccountInfo"
            Visible="False"
            HorizontalExpand="True"
            Orientation="Vertical"
            Margin="16">

            <Label Name="AccountName" Align="Center"/>
            <Label Name="AccountStored" Align="Center"/>

            <PanelContainer VerticalExpand="True" VerticalAlignment="Bottom">
                <PanelContainer.PanelOverride>
                    <graphics:StyleBoxFlat BackgroundColor="#B2BEB5" BorderThickness="5" BorderColor="#191d1e"/>
                </PanelContainer.PanelOverride>

                <BoxContainer Align="Center" SeparationOverride="10" Margin="8">
                    <Button Name="DepositButton" Text="Deposit"/>
                    <Button Name="WithdrawButton" Text="Withdraw"/>
                </BoxContainer>

            </PanelContainer>

        </BoxContainer>
    </BoxContainer>
</controls:FancyWindow>
