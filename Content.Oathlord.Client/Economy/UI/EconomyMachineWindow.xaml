<controls:FancyWindow
    xmlns="https://spacestation14.io"
    xmlns:graphics="clr-namespace:Robust.Client.Graphics;assembly=Robust.Client"
    xmlns:controls="clr-namespace:Content.Client.UserInterface.Controls;assembly=Content.Client"
    MinSize="700 620"
    Title="Bank Machine"
    Resizable="False">
    <!-- This is used for listing all accounts in the economy -->
    <ScrollContainer HorizontalAlignment="Left"
                     Margin="16 8 0 8"
                     HScrollEnabled="False"
                     MinSize="175 260"
                     VScrollEnabled="True">
        <PanelContainer>
            <PanelContainer.PanelOverride>
                <graphics:StyleBoxFlat BackgroundColor="#191d1e" />
            </PanelContainer.PanelOverride>
        </PanelContainer>
        <BoxContainer
            Name="Accounts"
            Margin="16 16 16 16"
            Orientation="Vertical"
            MinHeight="120"
            HorizontalExpand="True"/> <!-- Contents are autogenerated on runtime -->
    </ScrollContainer>

    <!-- This is used for operating on a specific account in the economy -->
    <BoxContainer HorizontalAlignment="Right"
                  MinSize="500 260"
                  Margin="16 8 8 8">
        <Label Text="Select an account from the menu on your right"
               HorizontalExpand="True"
               HorizontalAlignment="Center"
               VerticalAlignment="Top"/>
    </BoxContainer>
</controls:FancyWindow>
